{
  "name": "@gas-plugin/cli",
  "version": "0.1.1",
  "description": "Extensible CLI tool for scaffolding Google Apps Script projects",
  "type": "module",
  "bin": {
    "gas-plugin": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./create": {
      "types": "./dist/commands/create.d.ts",
      "import": "./dist/commands/create.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "vite build"
  },
  "keywords": [
    "google-apps-script",
    "gas",
    "cli",
    "scaffold",
    "create",
    "unplugin"
  ],
  "author": "wakita181009",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "citty": "^0.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@gas-plugin/unplugin": "workspace:*",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/google-apps-script": "^2.0.8",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.27.0",
    "rollup": "^4.59.0",
    "ts-loader": "^9.5.0",
    "tslib": "^2.8.1",
    "typescript": "^5.8.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.0",
    "webpack": "^5.105.0",
    "webpack-cli": "^6.0.1"
  }
}
