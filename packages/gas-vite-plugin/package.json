{
  "name": "gas-vite-plugin",
  "version": "0.0.10",
  "description": "A minimal Vite plugin for Google Apps Script projects",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "vite build"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "google-apps-script",
    "gas",
    "clasp"
  ],
  "author": "tetsuyawakita",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wakita181009/gas-vite-plugin"
  },
  "homepage": "https://github.com/wakita181009/gas-vite-plugin#readme",
  "dependencies": {
    "tinyglobby": "^0.2.15"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.0"
  }
}
