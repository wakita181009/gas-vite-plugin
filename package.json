{
  "name": "gas-plugin-monorepo",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "test:e2e": "pnpm --filter @gas-plugin/unplugin build && vitest run --config e2e/vitest.config.ts",
    "check": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome"
    ]
  },
  "packageManager": "pnpm@10.32.1"
}
